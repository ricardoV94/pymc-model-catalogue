     """
-    try:
-        return cache[dtype]
-    except KeyError:
-        cache[dtype] = res = ScalarType(dtype=dtype)
-    return res
+    if dtype not in cache:
+        cache[dtype] = ScalarType(dtype=dtype)
+    return cache[dtype]
 
 
