From edcf632425b74c03f933bf11e28d580667b462b5 Mon Sep 17 00:00:00 2001
From: ci <ci@example.com>
Date: Mon, 4 May 2026 08:54:55 +0200
Subject: [PATCH] Fix supports_c_code: remove compute_test_value

The reverted supports_c_code uses config.change_flags(compute_test_value=...)
but that config flag was removed from pytensor main. Without this fix
FusionOptimizer silently fails and produces a completely unfused graph.
---
 pytensor/scalar/basic.py | 3 +--
 1 file changed, 1 insertion(+), 2 deletions(-)

diff --git a/pytensor/scalar/basic.py b/pytensor/scalar/basic.py
index 71605fc..3588f6f 100644
--- a/pytensor/scalar/basic.py
+++ b/pytensor/scalar/basic.py
@@ -1325,8 +1325,7 @@ class ScalarOp(COp):
                     tmp_s_input.append(tmp)
                     mapping[ii] = tmp_s_input[-1]
 
-            with config.change_flags(compute_test_value="ignore"):
-                s_op = self(*tmp_s_input, return_list=True)
+            s_op = self(*tmp_s_input, return_list=True)
 
             # if the scalar_op don't have a c implementation,
             # we skip its fusion to allow the fusion of the
-- 
2.54.0

